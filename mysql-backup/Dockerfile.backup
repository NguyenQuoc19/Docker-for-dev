FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    default-mysql-client \
    cron \
    gzip \
    pigz \
    logrotate \
    nginx \
    curl \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /scripts

COPY scripts/backup/ /scripts/
COPY scripts/.my.cnf /scripts/.my.cnf
COPY scripts/cron/crontab /etc/cron.d/backup
COPY scripts/nginx/nginx.conf /etc/nginx/nginx.conf
COPY logs/logrotate-mysql-backup /etc/logrotate.d/mysql-backup

COPY .env /.env

RUN chmod +x /scripts/backup.sh \
    && chmod +x /scripts/backup-single.sh \
    && chmod +x /scripts/list-backups.sh \
    && chmod +x /scripts/import.sh \
    && chmod +x /scripts/entrypoint.sh \
    && chmod 0644 /etc/cron.d/backup \
    && crontab /etc/cron.d/backup \
    && touch /var/log/backup.log

EXPOSE 8080

ENTRYPOINT ["/scripts/entrypoint.sh"]
