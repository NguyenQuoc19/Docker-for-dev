# MySQL Connection
# ================
MYSQL_HOST=db-mysql
MYSQL_PORT=3306
MYSQL_USER=admin
MYSQL_PASSWORD=change_this_password

# Databases to create on MySQL container init (space separated)
# ================================
# Example: "test"
MYSQL_DATABASE="test"

# Databases to backup (space separated)
# ==============================
# Example: "test" or "test housai database3"
# Can be different from MYSQL_DATABASES
BACKUP_DATABASES="test housai"

# Backup Settings
# ==============
LOG_FILE=/var/log/mysql-backup.log
BACKUP_DIR=/backups

# Retention days - delete backups older than this many days
# ==================
RETENTION_DAYS=7

# Compression level (1-9)
# ======================
# 1 = fastest, 9 = smallest (slower)
# Default: 6 (balanced)
# Using pigz (parallel gzip) for multi-core compression
COMPRESSION_LEVEL=6

# Cron Schedule
# ============
# Default: daily at 2:00 AM
# Format: minute hour day month weekday
CRON_SCHEDULE="0 2 * * *"
# Examples:
#   */5 * * * *     - every 5 minutes
#   0 * * * *       - every hour
#   0 2 * * *       - daily at 2:00 AM
#   0 2 * * 0       - weekly on Sunday at 2:00 AM

# Security: IP allowed to download backups
=====
# Options:
# =================================#   - Specific IP: 192.168.1.100
#   - IP range (CIDR): 192.168.1.0/24
#   - Multiple IPs: 192.168.1.100 192.168.1.101
#   - All IPs: all
ALLOWED_IP=all

# Port for backup download
# ======================
# Leave empty to disable external access (e.g., BACKUP_PORT=)
# Set port number to enable (e.g., BACKUP_PORT=8081)
# When disabled, you can only download from inside container:
#   docker cp db-backup:/backups/backup.sql.gz ./
BACKUP_PORT=8081
